# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

# Find the project base directory
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR="$( cd "$( dirname "$0" )" && pwd -P )"
fi
export MAVEN_PROJECTBASEDIR

# Find java
if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
elif [ -f "/usr/lib/jvm/java-17-openjdk-amd64/bin/java" ]; then
  JAVACMD="/usr/lib/jvm/java-17-openjdk-amd64/bin/java"
else
  JAVACMD="$(which java)"
fi

if [ -z "$JAVACMD" ] || [ ! -f "$JAVACMD" ]; then
  echo "Error: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
  echo "Please set the JAVA_HOME variable in your environment to match the" >&2
  echo "location of your Java installation." >&2
  exit 1
fi

# Determine wrapper jar and properties
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

DISTRIBUTION_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_VERSION=$(echo "$DISTRIBUTION_URL" | sed 's/.*apache-maven-\([0-9.]*\)-.*/\1/')
MAVEN_HOME="$MAVEN_USER_HOME/wrapper/dists/apache-maven-$MAVEN_VERSION-bin/apache-maven-$MAVEN_VERSION"

# Download Maven if needed
if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Apache Maven $MAVEN_VERSION..."
  mkdir -p "$MAVEN_USER_HOME/wrapper/dists"
  TMP_DOWNLOAD_DIR=$(mktemp -d)
  ZIP_FILE="$TMP_DOWNLOAD_DIR/maven.zip"

  if command -v curl > /dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$ZIP_FILE"
  elif command -v wget > /dev/null 2>&1; then
    wget -q "$DISTRIBUTION_URL" -O "$ZIP_FILE"
  else
    echo "Error: curl or wget is required to download Maven." >&2
    exit 1
  fi

  unzip -q "$ZIP_FILE" -d "$MAVEN_USER_HOME/wrapper/dists"
  rm -rf "$TMP_DOWNLOAD_DIR"
  echo "Maven $MAVEN_VERSION downloaded."
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
